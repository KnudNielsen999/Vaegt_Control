@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Vægt Control</PageTitle>

@if (isAuthenticated)
{
    <div class="landing-redirect">
        <h3>Du er allerede logget ind</h3>
        <p>Gå direkte til dit dashboard.</p>
        <a class="btn btn-primary btn-lg" href="/dashboard">Åbn dashboard</a>
    </div>
}
else
{
    <div class="landing-hero">
        <div class="landing-overlay">
            <div class="landing-content">
                <h1>Vægt Control</h1>
                <p class="lead-text">
                    Hold styr på din vægt, følg udviklingen dag for dag,
                    og se hvor tæt du er på dit mål.
                </p>

                <div class="hero-buttons">
                    <a class="btn btn-primary btn-lg" href="/Account/Login">Log ind</a>
                    <a class="btn btn-outline-light btn-lg" href="/Account/Register">Opret bruger</a>
                </div>
            </div>
        </div>
    </div>

    <section class="feature-section">
        <div class="feature-grid">
            <div class="feature-card">
                <h3>Daglig registrering</h3>
                <p>Gem din vægt hurtigt og nemt hver dag.</p>
            </div>

            <div class="feature-card">
                <h3>Grafisk overblik</h3>
                <p>Se din udvikling i kurver og få overblik over din fremgang.</p>
            </div>

            <div class="feature-card">
                <h3>Mål og motivation</h3>
                <p>Følg din målvægt, forventet vægt og BMI på en enkel måde.</p>
            </div>
        </div>
    </section>
}

@code {
    private bool isAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
    }
}